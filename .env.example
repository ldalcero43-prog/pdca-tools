# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pdca:pdca123@localhost:5432/pdca_db
DIRECT_URL=postgresql://pdca:pdca123@localhost:5432/pdca_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=pdca_access
MINIO_SECRET_KEY=pdca_secret_key_change_me
MINIO_BUCKET=pdca-files
MINIO_USE_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_256_bit_random_secret_key_in_production
JWT_REFRESH_SECRET=change_me_to_another_256_bit_random_secret_key
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── AI (OpenAI compatible) ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── LGPD ─────────────────────────────────────────────────────────────────────
LGPD_DPO_EMAIL=dpo@yourdomain.com
LGPD_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
